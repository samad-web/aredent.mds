# Supabase connection — copy to .env and fill in from your project's
# Settings → API page. .env is gitignored.

# Server-side / seed loader (NEVER expose the service_role key to the browser):
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Client-side (only needed if the browser queries Supabase directly).
# Vite exposes VITE_*-prefixed vars to the frontend bundle — anon key only.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
